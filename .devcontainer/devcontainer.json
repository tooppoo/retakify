{
  "name": "retakify-dev",
  "image": "mcr.microsoft.com/devcontainers/base:2.1.9-trixie",
  "workspaceFolder": "/workspaces/retakify",
  "remoteUser": "vscode",
  "runArgs": [
    "--init"
  ],
  "postCreateCommand": "sh scripts/setup-dev.sh",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/go:1.3.4": {
      "version": "1.26.4"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "go.useLanguageServer": true,
        "go.formatTool": "gofmt"
      }
    }
  }
}
